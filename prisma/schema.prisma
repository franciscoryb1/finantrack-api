datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =========================
// ENUMS
// =========================

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum MovementType {
  INCOME
  EXPENSE
  STATEMENT_PAYMENT
  TRANSFER_OUT
  TRANSFER_IN
  BALANCE_ADJUSTMENT
}

enum AccountType {
  CASH
  BANK
  CREDIT_CARD
  WALLET
}

enum CategoryType {
  INCOME
  EXPENSE
}

// =========================
// MODELS
// =========================

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  phoneNumber  String? @unique @db.VarChar(30)
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokenHash String?

  accounts     Account[]
  categories   Category[]
  movements    Movement[]
  recurringExpenses RecurringExpense[]
  tags         Tag[]

  creditCards             CreditCard[]
  creditCardPurchases     CreditCardPurchase[]
  creditCardInstallments  CreditCardInstallment[]
  creditCardStatements    CreditCardStatement[]
  creditCardPayments      CreditCardPayment[]
  accountTransfers        AccountTransfer[]
}

model Account {
  id                   Int         @id @default(autoincrement())
  userId               Int
  name                 String
  type                 AccountType
  currentBalanceCents  Int         @default(0)
  isActive             Boolean     @default(true)

  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  user                 User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements            Movement[]

  creditCardsAsBank      CreditCard[] @relation("AccountAsBankForCards")
  creditCardPayments     CreditCardPayment[]
  transfersFrom          AccountTransfer[] @relation("TransferFromAccount")
  transfersTo            AccountTransfer[] @relation("TransferToAccount")
  purchaseReimbursements CreditCardPurchase[] @relation("PurchaseReimbursementAccount")

  @@index([userId])
}


model Category {
  id        Int          @id @default(autoincrement())
  name      String
  type      CategoryType
  color     String?

  userId    Int?
  parentId  Int?
  isActive  Boolean      @default(true)

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[]   @relation("CategoryHierarchy")
  movements Movement[]
  creditCardPurchases CreditCardPurchase[]
  recurringExpenses   RecurringExpense[]

  @@unique([name, userId, parentId])
  @@index([userId])
  @@index([parentId])
}


model Movement {
  id          Int          @id @default(autoincrement())
  userId      Int
  accountId   Int
  categoryId  Int?
  type        MovementType
  amountCents Int
  balanceSnapshotCents Int
  occurredAt  DateTime
  description String?
  sharedAmountCents              Int?
  sharedFromMovementId           Int?
  sharedFromCreditCardPurchaseId Int?

  isDeleted   Boolean      @default(false)

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  creditCardPayment  CreditCardPayment?
  transferOut        AccountTransfer? @relation("TransferFromMovement")
  transferIn         AccountTransfer? @relation("TransferToMovement")
  recurringPayment   RecurringExpensePayment?
  reimbursedPurchase CreditCardPurchase? @relation("PurchaseReimbursementMovement")
  tags               Tag[]
  sharedReimbursements         Movement[]          @relation("MovementSharedReimbursements")
  sharedFromMovement           Movement?           @relation("MovementSharedReimbursements", fields: [sharedFromMovementId], references: [id], onDelete: SetNull)
  sharedFromPurchase           CreditCardPurchase? @relation("PurchaseSharedReimbursements", fields: [sharedFromCreditCardPurchaseId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([userId, isDeleted])
  @@index([accountId])
  @@index([categoryId])
  @@index([sharedFromMovementId])
  @@index([sharedFromCreditCardPurchaseId])
}





enum CreditCardBrand {
  VISA
  MASTERCARD
  AMEX
  OTHER
}

enum CreditCardStatementStatus {
  OPEN
  CLOSED
  PAID
}

enum CreditCardInstallmentStatus {
  PENDING
  BILLED
  PAID
}


model CreditCard {
  id            Int              @id @default(autoincrement())
  userId        Int
  bankAccountId Int

  name          String
  brand         CreditCardBrand? // opcional
  limitCents    Int

  cardLast4     String
  cardExpiresAt DateTime

  backgroundColor String? @default("#ffffff")

  isActive      Boolean          @default(true)

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount   Account          @relation("AccountAsBankForCards", fields: [bankAccountId], references: [id], onDelete: Restrict)

  purchases     CreditCardPurchase[]
  statements    CreditCardStatement[]

  @@index([userId])
  @@index([bankAccountId])
}

model CreditCardPurchase {
  id                Int       @id @default(autoincrement())
  userId             Int
  creditCardId       Int
  categoryId         Int?
  firstStatementSequence Int

  totalAmountCents   Int
  installmentsCount  Int       // >= 1
  occurredAt         DateTime
  description        String?
  sharedAmountCents Int?

  // Reintegro promocional (opcional)
  reimbursementAmountCents Int?
  reimbursementAccountId   Int?
  reimbursementAt          DateTime?
  reimbursementMovementId  Int?      @unique

  isDeleted          Boolean   @default(false)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard         CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Restrict)
  category           Category?  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  reimbursementAccount  Account?  @relation("PurchaseReimbursementAccount", fields: [reimbursementAccountId], references: [id], onDelete: Restrict)
  reimbursementMovement Movement? @relation("PurchaseReimbursementMovement", fields: [reimbursementMovementId], references: [id], onDelete: SetNull)
  sharedReimbursements Movement[] @relation("PurchaseSharedReimbursements")

  installments       CreditCardInstallment[]

  @@index([userId, occurredAt])
  @@index([creditCardId])
  @@index([categoryId])
}

model CreditCardInstallment {
  id                 Int                         @id @default(autoincrement())
  userId             Int
  purchaseId         Int
  billingCycleOffset Int
  statementId        Int?

  installmentNumber  Int
  amountCents        Int

  year               Int?
  month              Int?


  status             CreditCardInstallmentStatus @default(PENDING)

  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  user               User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchase           CreditCardPurchase          @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  statement          CreditCardStatement?        @relation(fields: [statementId], references: [id], onDelete: SetNull)

  @@index([userId, year, month])
  @@index([purchaseId])
  @@index([statementId])
}

model CreditCardStatement {
  id              Int                     @id @default(autoincrement())
  userId          Int
  creditCardId    Int
  sequenceNumber  Int

  year            Int
  month           Int

  periodStartDate DateTime
  closingDate     DateTime
  dueDate         DateTime

  totalCents      Int                     @default(0)
  status          CreditCardStatementStatus @default(OPEN)

  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditCard      CreditCard              @relation(fields: [creditCardId], references: [id], onDelete: Restrict)

  installments    CreditCardInstallment[]
  payments        CreditCardPayment[]

  @@unique([creditCardId, year, month])
  @@index([userId])
  @@index([creditCardId, status])
}

model CreditCardPayment {
  id               Int       @id @default(autoincrement())
  userId           Int
  statementId      Int
  paidFromAccountId Int
  movementId       Int?      @unique

  amountCents      Int
  paidAt           DateTime

  createdAt        DateTime  @default(now())

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  statement        CreditCardStatement @relation(fields: [statementId], references: [id], onDelete: Restrict)
  paidFromAccount  Account   @relation(fields: [paidFromAccountId], references: [id], onDelete: Restrict)
  movement         Movement? @relation(fields: [movementId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([statementId])
  @@index([paidFromAccountId])
}

model AccountTransfer {
  id              Int      @id @default(autoincrement())
  userId          Int
  fromAccountId   Int
  toAccountId     Int
  amountCents     Int
  description     String?
  transferredAt   DateTime
  fromMovementId  Int      @unique
  toMovementId    Int      @unique

  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAccount     Account  @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount       Account  @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Restrict)
  fromMovement    Movement @relation("TransferFromMovement", fields: [fromMovementId], references: [id], onDelete: Restrict)
  toMovement      Movement @relation("TransferToMovement", fields: [toMovementId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model RecurringExpense {
  id          Int                @id @default(autoincrement())
  userId      Int
  name        String
  description String?
  amountCents    Int
  frequency      RecurringFrequency
  dueDay         Int?               // día del mes (1-31), solo aplica para MONTHLY
  dueDayOfWeek   Int?               // día de la semana (0=Dom..6=Sáb), solo aplica para WEEKLY/BIWEEKLY
  startDate      DateTime
  endDate     DateTime?
  categoryId  Int?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  payments    RecurringExpensePayment[]

  @@index([userId])
  @@index([categoryId])
}

model Tag {
  id        Int      @id @default(autoincrement())
  userId    Int
  name      String
  color     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements Movement[]

  @@unique([name, userId])
  @@index([userId])
}

model RecurringExpensePayment {
  id                 Int              @id @default(autoincrement())
  recurringExpenseId Int
  movementId         Int              @unique
  dueDate            DateTime
  amountCents        Int
  createdAt          DateTime         @default(now())

  recurringExpense   RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  movement           Movement         @relation(fields: [movementId], references: [id], onDelete: Restrict)

  @@index([recurringExpenseId])
  @@unique([recurringExpenseId, dueDate])
}
